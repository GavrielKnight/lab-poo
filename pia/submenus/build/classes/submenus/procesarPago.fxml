<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
   </padding>
   <children>
      <Label text="Procesador de Pagos" styleClass="titulo-submenu" />
      
      <VBox spacing="5.0" maxWidth="350.0">
         <children>
            <Label text="Monto a Cobrar:" />
            <TextField fx:id="montoCampo" editable="false" text="$350.00" />
         </children>
      </VBox>

      <VBox spacing="5.0" maxWidth="350.0">
         <children>
            <Label text="Número de Tarjeta (16 dígitos):" />
            <TextField fx:id="tarjetaCampo" promptText="4152 0000 0000 0000" />
         </children>
      </VBox>

      <HBox spacing="15.0" maxWidth="350.0" alignment="CENTER">
         <children>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Vencimiento:" />
                  <TextField fx:id="vencimientoCampo" promptText="MM/AA" />
               </children>
            </VBox>
            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="CVV:" />
                  <TextField fx:id="cvvCampo" promptText="123" />
               </children>
            </VBox>
         </HBox>
      </HBox>

      <ProgressIndicator fx:id="progresoIcono" visible="false" prefHeight="40.0" prefWidth="40.0" />
      
      <Label fx:id="estadoLabel" wrapText="true" alignment="CENTER" />

      <Button fx:id="botonPagar" mnemonicParsing="false" onAction="#handlePagarAction" text="Confirmar Pago" />
   </children>
</VBox>