<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane fx:id="mainContainer" prefHeight="200.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="submenus.MainLayout">
   <top>
      <ToolBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
        <items>
          <Button mnemonicParsing="false" onAction="#clientesBotonPresionado" text="Clientes" />
            <Button mnemonicParsing="false" onAction="#membresiasBotonPresionado" text="Membresias" />
            <Button mnemonicParsing="false" onAction="#inventarioBotonPresionado" text="Inventario" />
            <Button mnemonicParsing="false" onAction="#usuarioBotonPresionado" text="Usuario" />
        </items>
      </ToolBar>
   </top>
</BorderPane>
